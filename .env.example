# =============================================================================
# AEGIS X — 前端打包配置（复制为 `.env` 后修改）
# Vite 仅在 build/dev 时注入；生产 API 域名推导见 VITE_API_DERIVE_FROM_DOMAIN
# =============================================================================

# --- 钱包 / RPC ---
# 必填：thirdweb Dashboard → Settings → API Keys → Client ID
VITE_THIRDWEB_CLIENT_ID=replace-with-thirdweb-client-id

# 可选：WalletConnect Cloud Project ID（移动端 deep link 更稳定）
VITE_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id

# BSC RPC（链上读写）
VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org

# --- API ---
# 本地 dev / localhost：始终使用此地址（不根据域名拼接）
VITE_API_BASE_URL=https://api.xdpro.cc/api

# 生产环境：true=从访问域名推导 api.{rootDomain}/api；false=强制用 VITE_API_BASE_URL
VITE_API_DERIVE_FROM_DOMAIN=true

# 登录签名格式：siwe（EIP-4361）| simple
VITE_AUTH_MESSAGE_FORMAT=siwe

# BscScan 链接前缀
VITE_BSCSCAN_BASE_URL=https://bscscan.com

# --- Swap ---
# 默认滑点（bps，50 = 0.5%）
VITE_SWAP_DEFAULT_SLIPPAGE_BPS=50
# 交易 deadline（秒）
VITE_SWAP_DEADLINE_SECONDS=1200

# --- BSC 合约地址（留空则用代码内默认值）---
VITE_BSC_CHAIN_ID=56
VITE_BSC_WBNB=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
VITE_BSC_USD1_TEST=0x32Bb0be09F62bbE69764906d80e9A5782C7F7633
