# 必填：thirdweb Dashboard → Settings → API Keys → Client ID
# 未配置时 ConnectButton 会请求 1.rpc.thirdweb.com/YOUR_CLIENT_ID 并返回 401
VITE_THIRDWEB_CLIENT_ID=replace-with-thirdweb-client-id

# 可选：WalletConnect Cloud Project ID（移动端 deep link 更稳定）
VITE_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id

# 链上读写 RPC（默认 BSC 公开节点；也可填 Alchemy/Infura）
VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org

VITE_API_BASE_URL=https://api.xdpro.cc/api

# 登录签名消息格式：siwe（默认 EIP-4361）| simple
# 若后端验签失败，可切换为 simple 或向后端确认 message 模板
VITE_AUTH_MESSAGE_FORMAT=siwe
